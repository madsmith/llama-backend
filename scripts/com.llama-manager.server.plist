<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.llama-manager.server</string>
    <key>ProgramArguments</key>
    <array>
        <!-- Replace with: which llama-manager -->
        <string>/path/to/.venv/bin/llama-manager</string>
    </array>
    <key>WorkingDirectory</key>
    <!-- Replace with the project root (where server_config.json lives) -->
    <string>/path/to/llama-backend</string>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/llama-manager.stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/llama-manager.stderr.log</string>
</dict>
</plist>
